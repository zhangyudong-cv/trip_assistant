# 示例环境变量配置文件
# 使用方法：复制本文件为 .env 并填写你的 API Key

# 启动命令参考：
# .\venv\Scripts\activate
# $env:PYTHONPATH = ".\trip_assistant"
# python .\trip_assistant\graph_chat\第三个流程图.py

# --- 阿里云配置 (兼容 OpenAI 格式) ---
# 可见模型：qwen-max, qwen-plus, qwen-turbo
LLM_MODEL=qwen-max

# 嵌入模型建议：text-embedding-v3
EMBEDDING_MODEL=text-embedding-v3

# 你的阿里云 API Key (从 DashScope 控制台获取)
OPENAI_API_KEY=sk-xxxx... # 换成你自己的 API Key

# 阿里云 OpenAI 兼容端点 (固定值)
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 搜索工具配置 ---
# 从 https://tavily.com/ 获取
TAVILY_API_KEY=tvly-xxxx... # 换成你自己的 Tavily API Key
